generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id                String                 @id @default(uuid())
  name              String                 @unique
  slug              String                 @unique
  description       String                 @default("")
  isSystem          Boolean                @default(false) @map("is_system")
  isActive          Boolean                @default(true) @map("is_active")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  modulePermissions RoleModulePermission[]
  users             User[]

  @@map("roles")
}

model RoleModulePermission {
  id     String  @id @default(uuid())
  roleId String  @map("role_id")
  module String
  view   Boolean @default(false)
  create Boolean @default(false)
  edit   Boolean @default(false)
  delete Boolean @default(false)
  export Boolean @default(false)
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("role_module_permissions")
}

model Hospital {
  id              String                   @id @default(uuid())
  name            String
  contact         String                   @default("")
  email           String                   @default("")
  phone           String                   @default("")
  address         String                   @default("")
  city            String                   @default("")
  state           String                   @default("")
  pincode         String                   @default("")
  referenceBy     String                   @default("") @map("reference_by")
  referenceId       String?    @map("reference_id")
  reference         Reference? @relation(fields: [referenceId], references: [id])
  gstRate         Float                    @default(0) @map("gst_rate")
  tdsRate         Float                    @default(0) @map("tds_rate")
  invoicePrefix   String                   @default("FCC") @map("invoice_prefix")
  isActive        Boolean                  @default(true) @map("is_active")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")
  billingServices HospitalBillingService[]
  doctors         HospitalDoctor[]
  users           User[]
  claims          Claim[]
  submissions     DocumentSubmission[]
  invoices        Invoice[]

  @@map("hospitals")
}

model BillingServiceName {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  referenceApplicableTo ReferenceApplicableService[]

  @@map("billing_service_names")
}

model Reference {
  id              String   @id @default(uuid())
  name            String
  mobile          String   @default("")
  address         String   @default("")
  commissionRate  Float    @default(0) @map("commission_rate")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  applicableServices ReferenceApplicableService[]
  hospitals          Hospital[]

  @@index([name])
  @@map("references")
}

model ReferenceApplicableService {
  id                   String @id @default(uuid())
  referenceId          String @map("reference_id")
  billingServiceNameId String @map("billing_service_name_id")

  reference            Reference          @relation(fields: [referenceId], references: [id], onDelete: Cascade)
  billingServiceName   BillingServiceName @relation(fields: [billingServiceNameId], references: [id], onDelete: Cascade)

  @@unique([referenceId, billingServiceNameId])
  @@map("reference_applicable_services")
}

model Invoice {
  id                String   @id @default(uuid())
  invoiceNumber     String?  @unique @map("invoice_number")
  hospitalId        String   @map("hospital_id")
  month             DateTime
  status            String   @default("draft")
  issuedAt          DateTime? @map("issued_at")
  dueDate           DateTime? @map("due_date")

  subtotalTpaDesk   Float    @default(0) @map("subtotal_tpa_desk")
  subtotalServices  Float    @default(0) @map("subtotal_services")
  subtotalAdjust    Float    @default(0) @map("subtotal_adjustments")
  gross             Float    @default(0)
  gstRate           Float    @default(0) @map("gst_rate")
  gstAmount         Float    @default(0) @map("gst_amount")
  tdsRate           Float    @default(0) @map("tds_rate")
  tdsAmount         Float    @default(0) @map("tds_amount")
  netTotal          Float    @default(0) @map("net_total")
  previousBalance   Float    @default(0) @map("previous_balance")
  grandTotal        Float    @default(0) @map("grand_total")
  amountPaid        Float    @default(0) @map("amount_paid")
  amountPending     Float    @default(0) @map("amount_pending")

  notes             String   @default("")
  createdById       String?  @map("created_by_id")
  issuedById        String?  @map("issued_by_id")
  voidedAt          DateTime? @map("voided_at")
  voidReason        String   @default("") @map("void_reason")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  hospital  Hospital @relation(fields: [hospitalId], references: [id], onDelete: Restrict)
  createdBy User?    @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  issuedBy  User?    @relation("InvoiceIssuedBy", fields: [issuedById], references: [id])
  lineItems InvoiceLineItem[]

  @@unique([hospitalId, month])
  @@index([status])
  @@index([month])
  @@map("invoices")
}

model InvoiceLineItem {
  id                   String  @id @default(uuid())
  invoiceId            String  @map("invoice_id")
  lineType             String  @map("line_type")
  description          String
  amount               Float   @default(0)
  order                Int     @default(0)
  claimId              String? @map("claim_id")
  billingServiceId     String? @map("billing_service_id")
  billingServiceNameId String? @map("billing_service_name_id")
  meta                 Json    @default("{}")

  invoice              Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model HospitalBillingService {
  id                      String                       @id @default(uuid())
  hospitalId              String                       @map("hospital_id")
  serviceName             String                       @map("service_name")
  billingType             String                       @map("billing_type")
  fixedAmount             Float                        @default(0) @map("fixed_amount")
  claimLimit              Int                          @default(0) @map("claim_limit")
  overLimitBehavior       String                       @default("per_claim") @map("over_limit_behavior")
  overLimitPerClaimAmount Float                        @default(0) @map("over_limit_per_claim_amount")
  overLimitInsuranceWise  Boolean                      @default(false) @map("over_limit_insurance_wise")
  overLimitInsurerIds     Json                         @default("[]") @map("over_limit_insurer_ids")
  slabMode                String                       @default("slab_wise") @map("slab_mode")
  slabRangeStart          Float                        @default(0) @map("slab_range_start")
  slabRangeEnd            Float                        @default(50000) @map("slab_range_end")
  slabBasePrice           Float                        @default(2000) @map("slab_base_price")
  slabIncrementRange      Float                        @default(50000) @map("slab_increment_range")
  slabIncrementPrice      Float                        @default(500) @map("slab_increment_price")
  calculationBasis        String                       @default("none") @map("calculation_basis")
  percentageRate          Float                        @default(0) @map("percentage_rate")
  isActive                Boolean                      @default(true) @map("is_active")
  hospital                Hospital                     @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  slabs                   HospitalBillingServiceSlab[]

  @@map("hospital_billing_services")
}

model HospitalBillingServiceSlab {
  id               String                 @id @default(uuid())
  billingServiceId String                 @map("billing_service_id")
  rangeStart       Float                  @default(0) @map("range_start")
  rangeEnd         Float                  @default(0) @map("range_end")
  price            Float                  @default(0)
  order            Int                    @default(0)
  billingService   HospitalBillingService @relation(fields: [billingServiceId], references: [id], onDelete: Cascade)

  @@map("hospital_billing_service_slabs")
}

model HospitalDoctor {
  id             String   @id @default(uuid())
  hospitalId     String   @map("hospital_id")
  name           String
  specialization String   @default("")
  phone          String   @default("")
  email          String   @default("")
  hospital       Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@map("hospital_doctors")
}

model User {
  id                  String               @id @default(uuid())
  name                String
  email               String               @unique
  password            String
  roleId              String               @map("role_id")
  hospitalId          String?              @map("hospital_id")
  phone               String
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  role                Role                 @relation(fields: [roleId], references: [id])
  hospital            Hospital?            @relation(fields: [hospitalId], references: [id])
  claimsCreated       Claim[]              @relation("ClaimCreatedBy")
  claimsUpdated       Claim[]              @relation("ClaimUpdatedBy")
  claimStatusChanges  ClaimStatusHistory[] @relation("ClaimStatusChangedBy")
  documentSubmissions        DocumentSubmission[] @relation("SubmissionUploadedBy")
  statusChangedSubmissions   DocumentSubmission[] @relation("SubmissionStatusChangedBy")
  notifications              Notification[]
  employee                   Employee?
  invoicesCreated            Invoice[]            @relation("InvoiceCreatedBy")
  invoicesIssued             Invoice[]            @relation("InvoiceIssuedBy")

  @@map("users")
}

model InsuranceCompany {
  id            String   @id @default(uuid())
  name          String   @unique
  address       String   @default("")
  contactPerson String   @default("") @map("contact_person")
  mobile        String   @default("")
  email         String   @default("")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  claims        Claim[]

  @@map("insurance_companies")
}

model TPA {
  id            String   @id @default(uuid())
  name          String   @unique
  address       String   @default("")
  contactPerson String   @default("") @map("contact_person")
  mobile        String   @default("")
  email         String   @default("")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  claims        Claim[]

  @@map("tpas")
}

model ClaimStatus {
  id        String   @id @default(uuid())
  slug      String   @unique
  label     String
  color     String   @default("gray")
  order     Int      @default(0)
  isActive        Boolean  @default(true) @map("is_active")
  isSystem        Boolean  @default(false) @map("is_system")
  superAdminOnly  Boolean  @default(false) @map("super_admin_only")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("claim_statuses")
}

model ClaimDocumentType {
  id          String               @id @default(uuid())
  name        String               @unique
  description String               @default("")
  isRequired  Boolean              @default(false) @map("is_required")
  order       Int                  @default(0)
  isActive    Boolean              @default(true) @map("is_active")
  isSystem    Boolean              @default(false) @map("is_system")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  submissions DocumentSubmission[]

  @@map("claim_document_types")
}

model Claim {
  id                        String            @id @default(uuid())
  srNo                      Int               @default(autoincrement()) @map("sr_no")
  monthClaimNo              Int               @default(0) @map("month_claim_no")
  claimGenerateDate         DateTime          @default(now()) @map("claim_generate_date")
  status                    String            @default("admitted")
  hospitalId                String?           @map("hospital_id")
  isDirectPatient           Boolean           @default(false) @map("is_direct_patient")
  month                     DateTime
  patientName               String            @map("patient_name")
  patientMobile             String            @default("") @map("patient_mobile")
  doctorName                String            @default("") @map("doctor_name")
  claimType                 String            @map("claim_type")
  insuranceCompanyId        String?           @map("insurance_company_id")
  tpaId                     String?           @map("tpa_id")
  policyNo                  String            @default("") @map("policy_no")
  clientId                  String            @default("") @map("client_id")
  ccnNo                     String            @default("") @map("ccn_no")
  dateOfAdmit               DateTime          @map("date_of_admit")
  dateOfDischarge           DateTime?         @map("date_of_discharge")
  hospitalFinalBill         Float             @default(0) @map("hospital_final_bill")
  mouDiscount               Float             @default(0) @map("mou_discount")
  deduction                 Float             @default(0)
  finalApprovalAmount       Float             @default(0) @map("final_approval_amount")
  finalApprovalDate         DateTime?         @map("final_approval_date")
  fileReceivedDate          DateTime?         @map("file_received_date")
  submitMode                String            @default("") @map("submit_mode")
  courierSubmitDate         DateTime?         @map("courier_submit_date")
  onlineSubmitDate          DateTime?         @map("online_submit_date")
  courierCompanyName        String            @default("") @map("courier_company_name")
  podNumber                 String            @default("") @map("pod_number")
  settlementAmount          Float             @default(0) @map("settlement_amount")
  settlementAmountDeduction Float             @default(0) @map("settlement_amount_deduction")
  mouDiscountOnSettlement   Float             @default(0) @map("mou_discount_on_settlement")
  tds                       Float             @default(0)
  bankTransferAmount        Float             @default(0) @map("bank_transfer_amount")
  settlementDate            DateTime?         @map("settlement_date")
  neftNo                    String            @default("") @map("neft_no")
  filePrice                 Float             @default(0) @map("file_price")
  filePriceOverridden       Boolean           @default(false) @map("file_price_overridden")
  isBilled                  Boolean           @default(false) @map("is_billed")
  treatmentType             String            @default("") @map("treatment_type")
  diagnosis                 String            @default("")
  surgeryName               String            @default("") @map("surgery_name")
  remarks                   String            @default("")
  rejectedReason            String            @default("") @map("rejected_reason")
  createdById               String?           @map("created_by_id")
  updatedById               String?           @map("updated_by_id")
  createdAt                 DateTime          @default(now()) @map("created_at")
  updatedAt                 DateTime          @updatedAt @map("updated_at")
  hospital                  Hospital?         @relation(fields: [hospitalId], references: [id])
  insuranceCompany          InsuranceCompany? @relation(fields: [insuranceCompanyId], references: [id])
  tpa                       TPA?              @relation(fields: [tpaId], references: [id])
  createdBy                 User?             @relation("ClaimCreatedBy", fields: [createdById], references: [id])
  updatedBy                 User?             @relation("ClaimUpdatedBy", fields: [updatedById], references: [id])
  documents                 ClaimDocument[]
  submissions               DocumentSubmission[]
  statusHistory             ClaimStatusHistory[]

  @@index([createdAt(sort: Desc)])
  @@index([hospitalId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([month])
  @@index([ccnNo])
  @@index([patientName])
  @@map("claims")
}

model ClaimStatusHistory {
  id            String   @id @default(uuid())
  claimId       String   @map("claim_id")
  status        String
  changedAt     DateTime @default(now()) @map("changed_at")
  changedById   String?  @map("changed_by_id")
  claim         Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  changedBy     User?    @relation("ClaimStatusChangedBy", fields: [changedById], references: [id])

  @@index([claimId, changedAt])
  @@map("claim_status_history")
}

model ClaimDocument {
  id           String   @id @default(uuid())
  claimId      String   @map("claim_id")
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  filePath     String   @map("file_path")
  fileType     String?  @map("file_type")
  fileSize     Int?     @map("file_size")
  category     String   @default("other")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")
  claim        Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@map("claim_documents")
}

model DocumentSubmission {
  id             String            @id @default(uuid())
  hospitalId     String            @map("hospital_id")
  patientName    String            @map("patient_name")
  documentTypeId String?           @map("document_type_id")
  fileName       String            @map("file_name")
  originalName   String            @map("original_name")
  filePath       String            @map("file_path")
  fileType       String?           @map("file_type")
  fileSize       Int?              @map("file_size")
  status         String            @default("pending")
  claimId        String?           @map("claim_id")
  notes          String            @default("")
  uploadedById      String?           @map("uploaded_by_id")
  statusChangedById String?           @map("status_changed_by_id")
  statusChangedAt   DateTime?         @map("status_changed_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  hospital          Hospital          @relation(fields: [hospitalId], references: [id])
  documentType      ClaimDocumentType? @relation(fields: [documentTypeId], references: [id])
  claim             Claim?            @relation(fields: [claimId], references: [id])
  uploadedBy        User?             @relation("SubmissionUploadedBy", fields: [uploadedById], references: [id])
  statusChangedBy   User?             @relation("SubmissionStatusChangedBy", fields: [statusChangedById], references: [id])

  @@map("document_submissions")
}

model Notification {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  message     String
  type        String
  referenceId String?  @map("reference_id")
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ─── Staff Salary Module ───────────────────────────────────────────

model Employee {
  id            String              @id @default(uuid())
  empNumber     String              @unique @map("emp_number")
  name          String
  basicSalary   Float               @map("basic_salary")
  shiftStart    String              @map("shift_start")
  shiftEnd      String              @map("shift_end")
  standardHours Float               @map("standard_hours")
  userId        String?             @unique @map("user_id")
  isActive      Boolean             @default(true) @map("is_active")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  user          User?               @relation(fields: [userId], references: [id])
  allowances    EmployeeAllowance[]
  attendance    AttendanceRecord[]
  salaryRecords SalaryRecord[]

  @@map("employees")
}

model EmployeeAllowance {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  name       String
  amount     Float
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_allowances")
}

model HolidayMaster {
  id        String   @id @default(uuid())
  date      DateTime
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("holiday_master")
}

model AttendanceRecord {
  id           String    @id @default(uuid())
  employeeId   String    @map("employee_id")
  date         DateTime
  inTime       DateTime  @map("in_time")
  outTime      DateTime? @map("out_time")
  totalMinutes Int?      @map("total_minutes")
  extraMinutes Int?      @map("extra_minutes")
  otType       String    @default("none") @map("ot_type")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@map("attendance_records")
}

model SalaryRecord {
  id               String   @id @default(uuid())
  employeeId       String   @map("employee_id")
  month            DateTime
  basicSalary      Float    @map("basic_salary")
  calendarDays     Int      @map("calendar_days")
  presentDays      Int      @map("present_days")
  dailyOtMinutes   Int      @default(0) @map("daily_ot_minutes")
  sundayOtMinutes  Int      @default(0) @map("sunday_ot_minutes")
  holidayOtMinutes Int      @default(0) @map("holiday_ot_minutes")
  extraAllowances  Json     @default("[]") @map("extra_allowances")
  totalAmount      Float    @default(0) @map("total_amount")
  isFinalized      Boolean  @default(false) @map("is_finalized")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  employee         Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month])
  @@map("salary_records")
}

model OtSettings {
  id                String   @id @default(uuid())
  dailyMultiplier   Float    @default(1.5) @map("daily_multiplier")
  sundayMultiplier  Float    @default(2.0) @map("sunday_multiplier")
  holidayMultiplier Float    @default(2.0) @map("holiday_multiplier")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("ot_settings")
}

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}
